# ──────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────
# Which database backend to use. Defaults to "sqlite" for local/
# self-hosted installs. Set to "postgres" for cloud deployments.
DB_DIALECT=sqlite

# DATABASE_URL meaning depends on DB_DIALECT:
#
#   DB_DIALECT=sqlite   — filesystem path to the SQLite file.
#                         Default when unset: ./data/researchq.db
#                         Example: ./data/researchq.db
#
#   DB_DIALECT=postgres — Postgres connection string.
#                         Example: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=./data/researchq.db

# ──────────────────────────────────────────────────────────────────
# OpenAlex (paper discovery)
# ──────────────────────────────────────────────────────────────────
# Optional — providing an email gets you into OpenAlex's faster "polite"
# request pool. See https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_EMAIL=you@example.com

# ──────────────────────────────────────────────────────────────────
# LLM (Google Gemini — via Vercel AI Gateway OR directly via Google AI Studio)
# ──────────────────────────────────────────────────────────────────
# Which provider to use:
#   gateway (default) — Vercel AI Gateway. Free tier, no Google account
#                       needed. Requires AI_GATEWAY_KEY.
#   google            — Google AI Studio direct. Requires a Google AI
#                       Studio key (https://aistudio.google.com/apikey)
#                       set as GOOGLE_GENERATIVE_AI_API_KEY.
LLM_PROVIDER=gateway

# The Gemini model to use. The "google/" prefix is optional — the app
# adds or strips it to match your provider.
#   Gateway format: google/gemini-2.0-flash, google/gemini-2.5-flash, ...
#   Google format:  gemini-2.0-flash, gemini-2.5-flash, ...
LLM=google/gemini-2.0-flash

# ── If LLM_PROVIDER=gateway ──────────────────────────────────────
# Get a key at https://vercel.com/ai-gateway (free tier available)
AI_GATEWAY_KEY=

# ── If LLM_PROVIDER=google ───────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
